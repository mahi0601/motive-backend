# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Database (MongoDB Atlas or local) ───────────────────
# Use a NEW user/password — never reuse a leaked one.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/motive?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_32+_char_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── Refresh-token cookie ────────────────────────────────
# Same registrable domain (app.x.com + api.x.com): COOKIE_SAMESITE=lax, COOKIE_DOMAIN=.x.com
# Cross-site (vercel.app + onrender.com):           COOKIE_SAMESITE=none, COOKIE_SECURE=true (HTTPS)
COOKIE_NAME=motive_rt
COOKIE_SAMESITE=lax
# COOKIE_SECURE defaults to true in production; set explicitly if needed.
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.yourdomain.com

# ── CORS / frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (optional, for reminders) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_USERNAME=
EMAIL_PASSWORD=
